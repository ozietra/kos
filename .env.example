# ───────────────────────────────────────────────────────────────────────────
# kosgebhibe.com — Ortam Değişkenleri (ÖRNEK)
# Bu dosyayı ".env" adıyla kopyalayın ve değerleri doldurun.
# .env dosyası ASLA git'e gönderilmez (gizli bilgiler içerir).
# ───────────────────────────────────────────────────────────────────────────

# ── Genel ──
DEBUG=false
# Rastgele uzun bir gizli anahtar (oturum imzalama). En az 32 karakter.
SECRET_KEY=buraya-uzun-rastgele-bir-anahtar-yazin-32-karakterden-fazla
# Hassas verileri şifreleme anahtarı — TAM 32 karakter olmalı.
ENCRYPTION_KEY=tam-32-karakterlik-bir-anahtar!!

# ── Veritabanı (sunucuda yerel Postgres — docker-compose otomatik ayarlar) ──
POSTGRES_PASSWORD=guclu-bir-veritabani-sifresi

# ── Yapay metin üretimi (Groq) ──
# https://console.groq.com/keys adresinden ücretsiz API anahtarı alın.
GROQ_API_KEY=gsk_xxxxxxxxxxxxxxxxxxxxxxxx

# ── İlk yönetici ──
# Önce siteye normal kayıt olun, sonra e-postanızı buraya yazıp yeniden başlatın.
ADMIN_EMAIL=siz@ornek.com

# ── Cloudflare Tunnel (domain + SSL) ──
# Cloudflare Zero Trust > Networks > Tunnels'tan oluşturduğunuz tünelin token'ı.
CF_TUNNEL_TOKEN=eyJ...buraya-cloudflare-tunnel-token

# ── E-posta (SMTP) — şifre sıfırlama ve ödeme onayı için ──
SMTP_HOST=smtp.ornek.com
SMTP_PORT=587
SMTP_USER=noreply@kosgebhibe.com
SMTP_PASS=smtp-sifreniz
SMTP_FROM=noreply@kosgebhibe.com
FROM_EMAIL=noreply@kosgebhibe.com
FROM_NAME=kosgebhibe.com

# ── Ödeme: iyzico ──
# https://merchant.iyzipay.com adresinden API anahtarları.
IYZICO_API_KEY=
IYZICO_SECRET_KEY=
# Test için true, gerçek ödeme için false
IYZICO_SANDBOX=true

# ── Ödeme: PayTR ──
# https://www.paytr.com mağaza panelinden mağaza bilgileri.
PAYTR_MERCHANT_ID=
PAYTR_MERCHANT_KEY=
PAYTR_MERCHANT_SALT=
# Test için true, gerçek ödeme için false
PAYTR_SANDBOX=true

# Varsayılan ödeme sağlayıcısı: iyzico | paytr
DEFAULT_PAYMENT_PROVIDER=iyzico

# Ödeme zorunlu mu? (test için false yapabilirsiniz)
PAYMENT_REQUIRED=true
