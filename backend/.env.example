# ─── Temel ayarlar ───────────────────────────────────────────────────────────
DEBUG=false
SECRET_KEY=super-secret-jwt-key-change-this-in-production-min-32-chars
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# ─── Veritabanı ──────────────────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://kosgebhibe:kosgebhibe123@postgres:5432/kosgebhibe

# ─── Redis ───────────────────────────────────────────────────────────────────
REDIS_URL=redis://redis:6379

# ─── Gemini API ──────────────────────────────────────────────────────────────
# Google AI Studio'dan ücretsiz alınır: https://aistudio.google.com/
GEMINI_API_KEY=your-gemini-api-key-here
GEMINI_MODEL=gemini-2.5-flash

# ─── iyzico Ödeme ────────────────────────────────────────────────────────────
IYZICO_API_KEY=your-iyzico-api-key
IYZICO_SECRET_KEY=your-iyzico-secret-key
IYZICO_SANDBOX=true                          # false = production
IYZICO_BASE_URL=https://sandbox-api.iyzipay.com

# ─── E-posta (Postal SMTP) ───────────────────────────────────────────────────
SMTP_HOST=postal
SMTP_PORT=25
SMTP_USER=kosgebhibe
SMTP_PASS=your-postal-smtp-password          # aiosmtplib için
SMTP_FROM=noreply@kosgebhibe.com
FROM_EMAIL=noreply@kosgebhibe.com
FROM_NAME=kosgebhibe.com

# ─── Frontend URL ────────────────────────────────────────────────────────────
FRONTEND_URL=https://kosgebhibe.com
NEXT_PUBLIC_API_URL=https://kosgebhibe.com

# ─── Şifreleme (vergi numarası için AES-256) ─────────────────────────────────
# Tam olarak 32 karakter uzunluğunda bir anahtar girin
ENCRYPTION_KEY=change-this-encryption-key-32chars

# ─── Özellik bayrakları ───────────────────────────────────────────────────────
PAYMENT_REQUIRED=true                        # false = test modu (ücretsiz)
